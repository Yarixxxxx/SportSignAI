<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VideoAnalysis.App.ViewModels.Shell"
        xmlns:items="using:VideoAnalysis.App.ViewModels.Items"
        xmlns:converters="using:VideoAnalysis.App.Converters"
        xmlns:models="using:VideoAnalysis.Core.Models"
        x:Class="VideoAnalysis.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="960"
        Height="600"
        MinWidth="620"
        MinHeight="480"
        Title="VideoAnalytics - Плеер"
        Icon="/Assets/app-icon.ico"
        Background="#0D0D0E"
        Foreground="#E5EDF9"
        ClipToBounds="True">

  <Window.Resources>
    <converters:StringNullOrEmptyToBoolConverter x:Key="StringNullOrEmptyToBoolConverter"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.top-menu-bar">
      <Setter Property="Background" Value="#242426"/>
      <Setter Property="BorderBrush" Value="#3A3A3D"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="4,0"/>
    </Style>

    <Style Selector="Button.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="Button.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed">
      <Setter Property="Background" Value="#45454A"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked">
      <Setter Property="Background" Value="#3A3A3E"/>
    </Style>

    <Style Selector="Button.top-menu-item:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ToggleButton.top-menu-item:checked /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Border.file-menu-popup">
      <Setter Property="Background" Value="#FF20242C"/>
      <Setter Property="BorderBrush" Value="#526987"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="6"/>
      <Setter Property="BoxShadow" Value="0 12 30 0 #CC000000"/>
    </Style>

    <Style Selector="Button.file-menu-item">
      <Setter Property="Background" Value="#FF20242C"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="MinWidth" Value="260"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="Button.file-menu-item /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover">
      <Setter Property="Background" Value="#FF303948"/>
    </Style>

    <Style Selector="Button.file-menu-item:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="Button.player-button">
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.player-button:pointerover">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Button.player-control-button, ToggleButton.player-control-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.player-control-button:pointerover, ToggleButton.player-control-button:pointerover">
      <Setter Property="Background" Value="#263246"/>
    </Style>

    <Style Selector="Button.player-control-button:pressed, ToggleButton.player-control-button:checked">
      <Setter Property="Background" Value="#304563"/>
    </Style>

    <Style Selector="Button.broadcast-record-button">
      <Setter Property="Background" Value="#1F5EFF"/>
      <Setter Property="BorderBrush" Value="#4285FF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.broadcast-record-button:pointerover">
      <Setter Property="Background" Value="#2F73FF"/>
    </Style>

    <Style Selector="Button.broadcast-record-button:pressed">
      <Setter Property="Background" Value="#174DD6"/>
    </Style>

    <Style Selector="Border.player-control-bar">
      <Setter Property="Background" Value="#1D1D20"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="10,6,10,14"/>
      <Setter Property="BorderBrush" Value="#283244"/>
      <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="Border.player-seek-surface">
      <Setter Property="Height" Value="34"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-track">
      <Setter Property="Height" Value="7"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#53647F"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-seek-progress">
      <Setter Property="Height" Value="7"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#2F86FF"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Width" Value="0"/>
    </Style>

    <Style Selector="Border.player-volume-surface">
      <Setter Property="Width" Value="20"/>
      <Setter Property="Height" Value="108"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.player-volume-track">
      <Setter Property="Width" Value="6"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Background" Value="#53647F"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Border.player-volume-progress">
      <Setter Property="Width" Value="6"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Background" Value="#2F86FF"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Bottom"/>
      <Setter Property="Height" Value="0"/>
    </Style>

    <Style Selector="TextBox.player-input">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.player-input:pointerover">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input:focus">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.player-input /template/ Border">
      <Setter Property="Background" Value="#162238"/>
    </Style>

    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#151617"/>
      <Setter Property="BorderBrush" Value="#283244"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.panel-window-header">
      <Setter Property="Background" Value="#202123"/>
      <Setter Property="BorderBrush" Value="#344056"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>

    <Style Selector="Button.panel-window-button">
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="26"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#DCE6F5"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="Button.panel-window-button:pointerover">
      <Setter Property="Background" Value="#344056"/>
    </Style>

    <Style Selector="Button.panel-window-button.close-button:pointerover">
      <Setter Property="Background" Value="#B4232A"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBlock.section-subtitle">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.placeholder-card">
      <Setter Property="Background" Value="#1B1D21"/>
      <Setter Property="BorderBrush" Value="#344056"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.stats-header-card">
      <Setter Property="Background" Value="#151617"/>
      <Setter Property="BorderBrush" Value="#283244"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="18,16"/>
    </Style>

    <Style Selector="Border.stats-logo-placeholder">
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="44"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Background" Value="#4B5870"/>
      <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <Style Selector="Border.stats-bar-track">
      <Setter Property="Height" Value="8"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#1E2C42"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="ProgressBar.stats-bar-home">
      <Setter Property="Minimum" Value="0"/>
      <Setter Property="Foreground" Value="#FF2A2A"/>
      <Setter Property="Background" Value="#1E2C42"/>
      <Setter Property="Height" Value="8"/>
    </Style>

    <Style Selector="ProgressBar.stats-bar-away">
      <Setter Property="Minimum" Value="0"/>
      <Setter Property="Foreground" Value="#2F86FF"/>
      <Setter Property="Background" Value="#1E2C42"/>
      <Setter Property="Height" Value="8"/>
    </Style>

    <Style Selector="TextBox.event-type-input">
      <Setter Property="Background" Value="#121315"/>
      <Setter Property="BorderBrush" Value="#344056"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="CaretBrush" Value="#F7FAFF"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover">
      <Setter Property="Background" Value="#121315"/>
      <Setter Property="BorderBrush" Value="#3A567C"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus">
      <Setter Property="Background" Value="#121315"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ Border">
      <Setter Property="Background" Value="#121315"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ ContentControl#PART_Watermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ ContentControl#PART_FloatingWatermark">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:focus /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBox.event-type-input:pointerover /template/ TextBlock#PlaceholderTextBlock">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBlock.input-placeholder">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Margin" Value="12,0,12,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <Style Selector="TextBlock.project-input-placeholder">
      <Setter Property="Foreground" Value="#8FA3BF"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextAlignment" Value="Left"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="TextBlock.project-input-placeholder.multiline">
      <Setter Property="Margin" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style Selector="Button.action-button">
      <Setter Property="Background" Value="#1D5DFF"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="Button.action-button:pointerover">
      <Setter Property="Background" Value="#2F6DFF"/>
    </Style>

    <Style Selector="Button.event-eye-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#9EB5D4"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="MinWidth" Value="24"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.event-eye-button:pointerover">
      <Setter Property="Background" Value="#24324A"/>
      <Setter Property="Foreground" Value="#F7FAFF"/>
    </Style>

    <Style Selector="ListBox.event-type-list">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBox.event-type-list ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Border.panel-tabs">
      <Setter Property="Background" Value="#151617"/>
      <Setter Property="BorderBrush" Value="#283244"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="ToggleButton.tab-button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,1,1,0"/>
      <Setter Property="Foreground" Value="#A9B5C9"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="CornerRadius" Value="4,4,0,0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="ToggleButton.tab-button:pointerover">
      <Setter Property="Background" Value="#1E2737"/>
      <Setter Property="Foreground" Value="#DCE6F5"/>
    </Style>

    <Style Selector="ToggleButton.tab-button:checked">
      <Setter Property="Background" Value="#172D55"/>
      <Setter Property="BorderBrush" Value="#2F7BFF"/>
      <Setter Property="Foreground" Value="#4FA0FF"/>
    </Style>

    <Style Selector="Border.editor-overlay">
      <Setter Property="Background" Value="#A0000000"/>
    </Style>

    <Style Selector="Border.editor-dialog">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="MaxWidth" Value="420"/>
      <Setter Property="Margin" Value="16"/>
    </Style>

    <Style Selector="Border.editor-overlay">
      <Setter Property="Background" Value="#A0000000"/>
    </Style>

    <Style Selector="Border.editor-dialog">
      <Setter Property="Background" Value="#162238"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="MaxWidth" Value="420"/>
      <Setter Property="Margin" Value="16"/>
    </Style>

    <Style Selector="Border.new-project-dialog">
      <Setter Property="Background" Value="#2F2F32"/>
      <Setter Property="BorderBrush" Value="#4C566B"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Margin" Value="28"/>
      <Setter Property="MaxWidth" Value="900"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="TextBlock.dialog-title">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
    </Style>

    <Style Selector="TextBlock.dialog-subtitle">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#AAB3C3"/>
    </Style>

    <Style Selector="TextBlock.form-label">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#E2E8F3"/>
    </Style>

    <Style Selector="TextBox.project-form-input">
      <Setter Property="Background" Value="#1E1F22"/>
      <Setter Property="BorderBrush" Value="#365DA8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="CaretBrush" Value="#F5F7FB"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
      <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="TextBox.project-form-input:pointerover">
      <Setter Property="BorderBrush" Value="#4D79CB"/>
    </Style>

    <Style Selector="TextBox.project-form-input:focus">
      <Setter Property="BorderBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="TextBox.project-form-input /template/ Border">
      <Setter Property="Background" Value="#1E1F22"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style Selector="Border.project-form-shell">
      <Setter Property="Background" Value="#1E1F22"/>
      <Setter Property="BorderBrush" Value="#365DA8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="Border.project-form-shell.single-line">
      <Setter Property="Padding" Value="14,8"/>
    </Style>

    <Style Selector="TextBox.project-form-plain-input">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="#F5F7FB"/>
      <Setter Property="CaretBrush" Value="#F5F7FB"/>
      <Setter Property="SelectionBrush" Value="#2F86FF"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="TextBox.project-form-plain-input.single-line">
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBox.project-form-plain-input /template/ Border">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.layout-choice-button">
      <Setter Property="Background" Value="#1B1C20"/>
      <Setter Property="BorderBrush" Value="#3B4658"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12"/>
      <Setter Property="Foreground" Value="#DCE6F5"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Button.layout-choice-button:pointerover">
      <Setter Property="Background" Value="#222A38"/>
      <Setter Property="BorderBrush" Value="#2F86FF"/>
    </Style>

    <Style Selector="Border.layout-preview">
      <Setter Property="Height" Value="54"/>
      <Setter Property="Background" Value="#101216"/>
      <Setter Property="BorderBrush" Value="#243FFF"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.layout-preview-line">
      <Setter Property="Background" Value="#243FFF"/>
    </Style>

    <Style Selector="Border.workspace-empty-slot">
      <Setter Property="Background" Value="#111317"/>
      <Setter Property="BorderBrush" Value="#2B3C59"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="18"/>
