  </Window.Styles>

  <Grid RowDefinitions="Auto,*" Background="#0D0D0E" ClipToBounds="True">
    <Border x:Name="TopMenuBar" Grid.Row="0" Classes="top-menu-bar">
      <Grid ColumnDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="2">
          <ToggleButton x:Name="FileMenuButton"
                        Classes="top-menu-item"
                        Checked="OnFileMenuChecked"
                        Content="Файл"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=FileMenuButton}"
                 PlacementTarget="{Binding #FileMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Tag="NewProject" Content="Новый проект" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="OpenProjects" Content="Открыть..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="Save" Content="Сохранить" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="SaveAs" Content="Сохранить как..." Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="Export" Content="Экспорт" Click="OnFileMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="Exit" Content="Выход" Click="OnFileMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
          <ToggleButton x:Name="MarkupMenuButton"
                        Classes="top-menu-item"
                        Checked="OnMarkupMenuChecked"
                        Content="Разметка"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=MarkupMenuButton}"
                 PlacementTarget="{Binding #MarkupMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Режим разметки"/>
              </StackPanel>
            </Border>
          </Popup>

          <ToggleButton x:Name="ViewMenuButton"
                        Classes="top-menu-item"
                        Checked="OnViewMenuChecked"
                        Content="Вид"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=ViewMenuButton}"
                 PlacementTarget="{Binding #ViewMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item"
                        Tag="AddWorkspaceWindow"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="+"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Добавить окно"/>
                  </Grid>
                </Button>
                <Button Classes="file-menu-item"
                        Tag="TogglePlayerPanel"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsPlayerPanelVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Плеер"/>
                  </Grid>
                </Button>
                <Button Classes="file-menu-item"
                        Tag="ToggleBroadcastPanel"
                        IsVisible="{Binding IsBroadcastEntityAvailable}"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsBroadcastPanelVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Трансляция"/>
                  </Grid>
                </Button>
                <Button Classes="file-menu-item"
                        Tag="ToggleTimelinePanel"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsTimelineVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Таймлайн"/>
                  </Grid>
                </Button>
                <Button Classes="file-menu-item"
                        Tag="ToggleEventsPanel"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsEventsPanelVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="События"/>
                  </Grid>
                </Button>
                <Button Classes="file-menu-item"
                        Tag="ToggleAnalysisPanel"
                        Click="OnViewMenuActionClick">
                  <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                    <TextBlock Text="✓"
                               IsVisible="{Binding IsAnalysisPanelVisible}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4FA0FF"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Клипы"/>
                  </Grid>
                </Button>
              </StackPanel>
            </Border>
          </Popup>
          <ToggleButton x:Name="SettingsMenuButton"
                        Classes="top-menu-item"
                        Checked="OnSettingsMenuChecked"
                        Content="Настройки"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=SettingsMenuButton}"
                 PlacementTarget="{Binding #SettingsMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Настройки"/>
              </StackPanel>
            </Border>
          </Popup>
          <ToggleButton x:Name="HelpMenuButton"
                        Classes="top-menu-item"
                        Checked="OnHelpMenuChecked"
                        Content="Помощь"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=HelpMenuButton}"
                 PlacementTarget="{Binding #HelpMenuButton}"
                 Placement="Bottom"
                 HorizontalOffset="0"
                 VerticalOffset="4">
            <Border Classes="file-menu-popup">
              <StackPanel Spacing="2">
                <Button Classes="file-menu-item" Content="Документация" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="Горячие клавиши" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Tag="OpenLogsFolder" Content="Логи" Click="OnHelpMenuActionClick"/>
                <Button Classes="file-menu-item" Content="О программе" Click="OnHelpMenuActionClick"/>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="MainLayoutGrid" Grid.Row="1" Margin="0" Background="#0D0D0E" ClipToBounds="True">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3.2*" MinWidth="420"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.05*" MinWidth="250"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="1.45*" MinWidth="280"/>
      </Grid.ColumnDefinitions>

      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="260"/>
        <RowDefinition Height="6"/>
        <RowDefinition Height="240" MinHeight="170"/>
      </Grid.RowDefinitions>

      <Border x:Name="PlayerPanel" Grid.Row="0" Grid.Column="0" Classes="panel">
        <Grid RowDefinitions="Auto,*,Auto" ClipToBounds="True">
          <Border Grid.Row="0"
                  Classes="panel-window-header"
                  Cursor="SizeAll"
                  Tag="Player"
                  PointerPressed="OnPanelHeaderPointerPressed">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          VerticalAlignment="Center">
                <TextBlock Classes="section-title"
                           VerticalAlignment="Center"
                           Text="Плеер"/>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#8FA3BF"
                           FontSize="12">
                  <Run Text="{Binding CurrentTimeText}"/>
                  <Run Text=" / "/>
                  <Run Text="{Binding DurationTimeText}"/>
                </TextBlock>
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="4">
                <Button x:Name="PlayerDetachButton"
                        Classes="panel-window-button"
                        Tag="Player:Detach"
                        Click="OnPanelWindowControlClick"
                        ToolTip.Tip="Открыть плеер в отдельном окне"
                        Content="↗"/>
                <Button Classes="panel-window-button" Tag="Player:Minimize" Click="OnPanelWindowControlClick" Content="−"/>
                <Button Classes="panel-window-button" Tag="Player:Maximize" Click="OnPanelWindowControlClick" Content="□"/>
                <Button Classes="panel-window-button close-button" Tag="Player:Close" Click="OnPanelWindowControlClick" Content="×"/>
              </StackPanel>
            </Grid>
          </Border>

          <Border x:Name="PlayerSurfaceHost"
                  Grid.Row="1"
                  Background="#050B14"
                  BorderBrush="#111315"
                  BorderThickness="0"
                  CornerRadius="0"
                  ClipToBounds="True"
                  SizeChanged="OnPlayerSurfaceSizeChanged">
            <Grid x:Name="PlayerSurfaceLayer">
              <Grid x:Name="PlayerVideoPresenter"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

              <Border Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ZIndex="10"
                      PointerPressed="OnPlayerSurfacePointerPressed"
                      PointerMoved="OnPlayerSurfacePointerMoved"
                      PointerReleased="OnPlayerSurfacePointerReleased"
                      PointerWheelChanged="OnPlayerSurfacePointerWheelChanged"/>

              <Border HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="14"
                      Background="#B3000000"
                      CornerRadius="4"
                      Padding="10,6">
                <TextBlock Text="{Binding CurrentTimeText}"
                           Foreground="#F7FAFF"
                           FontSize="13"
                           FontWeight="Medium"/>
              </Border>

              <Border x:Name="VideoZoomDiagnosticsOverlay"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="12"
                      Padding="10,8"
                      Background="#D9000000"
                      BorderBrush="#31517A"
                      BorderThickness="1"
                      CornerRadius="4"
                      IsHitTestVisible="False"
                      IsVisible="False"
                      ZIndex="20">
                <TextBlock x:Name="VideoZoomDiagnosticsText"
                           Foreground="#D6E4F8"
                           FontFamily="Consolas"
                           FontSize="12"
                           LineHeight="16"/>
              </Border>

              <Border Width="64"
                      Height="64"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="#66FFFFFF"
                      CornerRadius="32"
                      IsVisible="{Binding ShowOverlayPlayButton}"
                      ZIndex="2">
                <Path Data="M 2 1 L 18 10 L 2 19 Z"
                      Fill="#FFFFFF"
                      Width="28"
                      Height="28"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="5,0,0,0"/>
              </Border>
            </Grid>
          </Border>

          <Border x:Name="PlayerControlsHost"
                  Grid.Row="2"
                  Classes="player-control-bar"
                  Background="#FF1D1D20"
                  BorderBrush="#283244"
                  BorderThickness="0,1,0,0"
                  CornerRadius="0"
                  Padding="10,6,10,14">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto"
                  ColumnSpacing="10"
                  VerticalAlignment="Center">
              <Button Grid.Column="0"
                      Classes="player-control-button"
                      Command="{Binding SeekBackwardTenSecondsCommand}">
                <TextBlock Text="-10"
                           FontSize="13"
                           FontWeight="SemiBold"/>
              </Button>

              <Button Grid.Column="1"
                      Classes="player-control-button"
                      Command="{Binding SeekBackwardFiveSecondsCommand}">
                <TextBlock Text="-5"
                           FontSize="13"
                           FontWeight="SemiBold"/>
              </Button>

              <Button Grid.Column="2"
                      Classes="player-control-button"
                      Command="{Binding TogglePlayPauseCommand}">
                <Grid Width="18"
                      Height="18">
                  <Path Data="M 2 1 L 16 9 L 2 17 Z"
                        Fill="#F7FAFF"
                        Stretch="Uniform"
                        IsVisible="{Binding !IsPlaying}"/>
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="4"
                        IsVisible="{Binding IsPlaying}">
                    <Border Width="4"
                            Height="16"
                            CornerRadius="1"
                            Background="#F7FAFF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    <Border Grid.Column="1"
                            Width="4"
                            Height="16"
                            CornerRadius="1"
                            Background="#F7FAFF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                  </Grid>
                </Grid>
              </Button>

              <Button Grid.Column="3"
                      Classes="player-control-button"
                      Command="{Binding SeekForwardFiveSecondsCommand}">
                <TextBlock Text="+5"
                           FontSize="13"
                           FontWeight="SemiBold"/>
              </Button>

              <Button Grid.Column="4"
                      Classes="player-control-button"
                      Command="{Binding SeekForwardTenSecondsCommand}">
                <TextBlock Text="+10"
                           FontSize="13"
                           FontWeight="SemiBold"/>
              </Button>

              <Border Grid.Column="5"
                      Classes="player-seek-surface"
                      Height="36"
                      Background="#101923"
                      CornerRadius="5"
                      Padding="0"
                      VerticalAlignment="Center"
                      PointerPressed="OnSeekBarPointerPressed"
                      PointerMoved="OnSeekBarPointerMoved"
                      PointerReleased="OnSeekBarPointerReleased">
                <Grid x:Name="SeekBarRoot"
                      Height="24"
                      VerticalAlignment="Center"
                      SizeChanged="OnSeekBarSizeChanged">
                  <Border Classes="player-seek-track"
                          Height="8"
                          Background="#71829E"
                          CornerRadius="4"
                          VerticalAlignment="Center"/>
                  <Border x:Name="SeekBarProgress"
                          Classes="player-seek-progress"
                          Height="8"
                          Background="#2F86FF"
                          CornerRadius="4"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Width="0"/>
                  <Ellipse x:Name="SeekBarThumb"
                           Width="20"
                           Height="20"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Fill="#2F86FF"
                           Stroke="#D9E5F8"
                           StrokeThickness="2"/>
                </Grid>
              </Border>

              <TextBlock Grid.Column="6"
                         VerticalAlignment="Center"
                         Foreground="#D9E5F8"
                         FontSize="14"
                         FontWeight="SemiBold">
                <Run Text="{Binding CurrentTimeText}"/>
                <Run Text=" / "/>
                <Run Text="{Binding DurationTimeText}"/>
              </TextBlock>

              <ToggleButton x:Name="SpeedMenuButton"
                            Grid.Column="7"
                            Classes="player-control-button"
                            Content="{Binding PlaybackRateText}"/>
              <Popup IsOpen="{Binding IsChecked, ElementName=SpeedMenuButton}"
                     PlacementTarget="{Binding #SpeedMenuButton}"
                     Placement="Top"
                     HorizontalOffset="0"
                     VerticalOffset="-8">
                <Border Classes="file-menu-popup"
                        Padding="6"
                        Background="#FF121821"
                        BorderBrush="#6B7E9F"
                        BorderThickness="1"
                        CornerRadius="5"
                        Opacity="1"
                        BoxShadow="0 16 40 0 #E6000000">
                  <ItemsControl ItemsSource="{Binding PlaybackRateOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Classes="file-menu-item"
                                MinWidth="86"
                                Background="#FF121821"
                                BorderBrush="#FF121821"
                                BorderThickness="0"
                                Foreground="#F7FAFF"
                                HorizontalContentAlignment="Left"
                                Padding="14,10"
                                CornerRadius="4"
                                Command="{Binding #RootWindow.DataContext.SetPlaybackRateCommand}"
                                CommandParameter="{Binding}"
                                Click="OnPlaybackRateMenuActionClick"
                                Content="{Binding}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
              </Popup>

              <ToggleButton x:Name="VolumeButton"
                            Grid.Column="8"
                            Classes="player-control-button">
                <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </ToggleButton>
              <Popup IsOpen="{Binding IsChecked, ElementName=VolumeButton}"
                     PlacementTarget="{Binding #VolumeButton}"
                     Placement="Top"
                     HorizontalOffset="-4"
                     VerticalOffset="-8">
                <Border x:Name="VolumePopupRoot"
                        Classes="file-menu-popup"
                        Padding="10,12"
                        Background="#FF121821"
                        BorderBrush="#6B7E9F"
                        BorderThickness="1"
                        CornerRadius="5"
                        Opacity="1"
                        BoxShadow="0 16 40 0 #E6000000">
                  <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <Button Classes="player-control-button"
                            Background="#24324A"
                            BorderBrush="#24324A"
                            BorderThickness="0"
                            Foreground="#F7FAFF"
                            HorizontalAlignment="Center"
                            Command="{Binding ToggleMuteCommand}">
                      <TextBlock Text="{Binding VolumeGlyph}" FontFamily="Segoe UI Symbol" FontSize="18"/>
                    </Button>
                    <Border Classes="player-volume-surface"
                            Width="24"
                            Height="112"
                            Background="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            PointerPressed="OnVolumeBarPointerPressed"
                            PointerMoved="OnVolumeBarPointerMoved"
                            PointerReleased="OnVolumeBarPointerReleased">
                      <Grid x:Name="VolumeBarRoot"
                            Width="20"
                            Height="108">
                        <Border Classes="player-volume-track"
                                Margin="0,9"
                                Width="7"
                                Background="#71829E"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"/>
                        <Border x:Name="VolumeBarProgress"
                                Classes="player-volume-progress"
                                Margin="0,9"
                                Width="7"
                                Background="#2F86FF"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Height="0"/>
                        <Ellipse x:Name="VolumeBarThumb"
                                 Width="18"
                                 Height="18"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Top"
                                 Fill="#2F86FF"/>
                      </Grid>
                    </Border>
                  </StackPanel>
                </Border>
              </Popup>

              <Button Grid.Column="9"
                      Classes="player-control-button"
                      Click="OnToggleFullscreenClick">
                <TextBlock Text="⛶" FontFamily="Segoe UI Symbol" FontSize="18"/>
              </Button>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <GridSplitter x:Name="EventsPanelSplitter" Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="1"
                    Width="6"
                    Background="#283244"
                    ResizeDirection="Columns"
                    PointerEntered="OnWorkspaceSplitterPointerEntered"
                    PointerExited="OnWorkspaceSplitterPointerExited"
                    HorizontalAlignment="Stretch"/>

      <Border x:Name="EventsPanel" Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="2"
              Classes="panel"
              Padding="0"
              IsVisible="{Binding IsEventsPanelVisible}">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0"
                  Classes="panel-window-header"
                  Cursor="SizeAll"
                  Tag="Events"
                  PointerPressed="OnPanelHeaderPointerPressed">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Classes="section-title"
                         Text="События"
                         VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                <Button Classes="panel-window-button" Tag="Events:Minimize" Click="OnPanelWindowControlClick" Content="−"/>
                <Button Classes="panel-window-button" Tag="Events:Maximize" Click="OnPanelWindowControlClick" Content="□"/>
                <Button Classes="panel-window-button close-button" Tag="Events:Close" Click="OnPanelWindowControlClick" Content="×"/>
              </StackPanel>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14" ClipToBounds="True">
              <Border Grid.Row="0" Classes="panel-tabs">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                  <ToggleButton Grid.Column="0"
                                Classes="tab-button"
                                IsChecked="{Binding IsEventTypesTabSelected}"
                                Command="{Binding SelectEventsPanelTabCommand}"
                                CommandParameter="EventTypes"
                                Content="Типы событий"/>
                  <ToggleButton Grid.Column="1"
                                Classes="tab-button"
                                IsChecked="{Binding IsEventsTabSelected}"
                                Command="{Binding SelectEventsPanelTabCommand}"
                                CommandParameter="Events"
                                Content="События"/>
                </Grid>
              </Border>

              <Grid Grid.Row="1"
                    Grid.RowSpan="3"
                    Margin="18,0,18,18"
                    RowDefinitions="Auto,*,Auto"
                    RowSpacing="10"
                    IsVisible="{Binding IsEventsTabSelected}">
                <TextBlock Text="События"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <ListBox Grid.Row="1"
                         Classes="event-type-list"
                         ItemsSource="{Binding TagEvents}"
                         SelectedItem="{Binding SelectedTagEvent, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#1A2640"
                              CornerRadius="8"
                              Padding="12,10"
                              DoubleTapped="OnTagEventItemDoubleTapped">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <TextBlock Text="{Binding PresetName}"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFF"/>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        HorizontalAlignment="Right">
                              <TextBlock Text="{Binding TeamSide}"
                                         Foreground="#9EB5D4"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Right"/>
                              <Button Classes="event-eye-button"
                                      HorizontalAlignment="Right"
                                      Click="OnTagEventPreviewClick">
                                <TextBlock Text="👁" FontSize="12"/>
                              </Button>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Classes="event-eye-button"
                                    Command="{Binding #RootWindow.DataContext.TogglePlaylistSelectionCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Top">
                              <TextBlock Text="{Binding PlaylistToggleGlyph}"
                                         FontSize="16"
                                         FontWeight="SemiBold"/>
                            </Button>
                          </Grid>
                          <TextBlock Grid.Row="1"
                                     Foreground="#C9D7EB"
                                     Text="{Binding StartTimeText, StringFormat='Старт: {0}'}"/>
                          <TextBlock Grid.Row="2"
                                     Foreground="#C9D7EB"
                                     Text="{Binding EndTimeText, StringFormat='Конец: {0}'}"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="10">
                  <Button Grid.Row="0"
                          Classes="action-button"
                          Command="{Binding OpenNewTagEventEditorCommand}"
                          Content="Новое событие"/>
                  <Button Grid.Row="1"
                          Classes="action-button"
                          Command="{Binding OpenAddToPlaylistDialogCommand}"
                          IsEnabled="{Binding CanOpenAddToPlaylistDialog}"
                          Content="Добавить в плейлист"/>
                </Grid>
              </Grid>

              <Grid Grid.Row="1"
                    Margin="18,0,18,0"
                    IsVisible="{Binding IsEventTypesTabSelected}">
                <StackPanel Spacing="10">
                  <TextBlock Text="Типы событий"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                  <ListBox Classes="event-type-list"
                           ItemsSource="{Binding EventTypeItems}"
                           SelectedItem="{Binding SelectedEventTypeItem, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="items:EventTypeItemViewModel">
                        <Border Background="#182031"
                                BorderBrush="{Binding ColorHex}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,9"
                                DoubleTapped="OnEventTypeItemDoubleTapped">
                          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border Width="30"
                                    Height="30"
                                    CornerRadius="5"
                                    Background="{Binding ColorHex}">
                              <TextBlock Text="{Binding Hotkey}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Foreground="#F7FAFF"
                                         FontWeight="Bold"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2">
                              <TextBlock Text="{Binding Name}"
                                         FontWeight="SemiBold"
                                         Foreground="#F7FAFF"/>
                              <TextBlock Text="{Binding Category}"
                                         Foreground="#DCE6F5"
                                         FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        Spacing="4"
                                        HorizontalAlignment="Right">
                              <TextBlock Text="{Binding EventCount}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Foreground="#F7FAFF"
                                         FontWeight="SemiBold"/>
                              <TextBlock Text="{Binding Hotkey}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Foreground="#DCE6F5"
                                         FontSize="12"
                                         FontWeight="SemiBold"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Grid>

              <Grid Grid.Row="3"
                    ColumnDefinitions="*"
                    ColumnSpacing="10"
                    Margin="18,0,18,18"
                    IsVisible="{Binding IsEventTypesTabSelected}">
                <Button Grid.Column="0"
                        Classes="action-button"
                        Command="{Binding OpenNewPresetEditorCommand}"
                        Content="Новый тип событий"/>
              </Grid>
            </Grid>
          </ScrollViewer>
          <Border Grid.Row="1"
                  Classes="editor-overlay"
                  IsVisible="{Binding IsAddToPlaylistDialogOpen}">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
              <Border Classes="editor-dialog"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="Добавить в плейлист"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <Button Grid.Column="1"
                            Classes="player-control-button"
                            Command="{Binding CloseAddToPlaylistDialogCommand}"
                            Content="X"/>
                  </Grid>

                  <StackPanel Grid.Row="1" Spacing="10">
                    <TextBlock Text="Выбранные события будут добавлены в существующий плейлист."
                               Foreground="#AAB9CF"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedPlaylistEventCount, StringFormat=Будет добавлено событий: {0}}"
                               Foreground="#DCE6F5"/>
                    <ComboBox ItemsSource="{Binding Playlists}"
                              SelectedItem="{Binding SelectedTargetPlaylistForAdd, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="items:PlaylistSummaryItemViewModel">
                          <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>

                  <Grid Grid.Row="2"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding AddSelectedEventsToPlaylistCommand}"
                            IsEnabled="{Binding CanAddSelectedEventsToPlaylist}"
                            Content="Добавить"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            Command="{Binding CloseAddToPlaylistDialogCommand}"
                            Content="Закрыть"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>


          <Border Grid.Row="1"
                  Classes="editor-overlay"
                  IsVisible="{Binding IsPresetEditorOpen}">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
              <Border Classes="editor-dialog"
                      x:Name="PresetEditorDialog"
                      Focusable="True"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding PresetEditorTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <Button x:Name="PresetEditorCloseButton"
                            Grid.Column="1"
                            Classes="player-control-button"
                            Command="{Binding ClosePresetEditorCommand}"
                            Content="X"/>
                  </Grid>

                  <StackPanel Grid.Row="1" Spacing="10">
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeName}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Название"
                                 IsVisible="{Binding EventTypeName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeHotkey, UpdateSourceTrigger=PropertyChanged}"
                               TextInput="OnEventTypeHotkeyTextInput"
                               TextChanged="OnEventTypeHotkeyTextChanged"
                               KeyDown="OnEventTypeHotkeyEditorKeyDown"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Hotkey"
                                 IsVisible="{Binding EventTypeHotkey, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeColor}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="#RRGGBB"
                                 IsVisible="{Binding EventTypeColor, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeCategory}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Категория"
                                 IsVisible="{Binding EventTypeCategory, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding EventTypeIconKey}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Icon key"
                                 IsVisible="{Binding EventTypeIconKey, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                      <StackPanel Spacing="6">
                        <TextBlock Text="Pre-roll"
                                   Foreground="#AAB9CF"
                                   FontSize="12"/>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypePreRollFrames}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1"
                                  Spacing="6">
                        <TextBlock Text="Post-roll"
                                   Foreground="#AAB9CF"
                                   FontSize="12"/>
                        <TextBox Classes="event-type-input"
                                 Text="{Binding EventTypePostRollFrames}"/>
                      </StackPanel>
                    </Grid>
                    <CheckBox Content="Показывать в статистике"
                              IsChecked="{Binding EventTypeShowInStatistics}"
                              Foreground="#DCE6F5"/>
                  </StackPanel>

                  <Grid Grid.Row="2"
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding SavePresetCommand}"
                            Content="Сохранить"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            IsVisible="{Binding IsEditingPreset}"
                            Command="{Binding DeletePresetCommand}"
                            IsEnabled="{Binding CanDeleteEditedPreset}"
                            Content="Удалить"/>
                    <Button Grid.Column="2"
                            Classes="action-button"
                            Command="{Binding ClosePresetEditorCommand}"
                            Content="Закрыть"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Classes="editor-overlay"
                  IsVisible="{Binding IsTagEventEditorOpen}">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
              <Border Classes="editor-dialog"
                      x:Name="TagEventEditorDialog"
                      Focusable="True"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding TagEventEditorTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <Button x:Name="TagEventEditorCloseButton"
                            Grid.Column="1"
                            Classes="player-control-button"
                            Command="{Binding CloseTagEventEditorCommand}"
                            Content="X"/>
                  </Grid>

                  <StackPanel Grid.Row="1" Spacing="10">
                    <ComboBox ItemsSource="{Binding TagPresets}"
                              SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:TagPreset">
                          <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBox Classes="event-type-input"
                               Watermark="Старт"
                               IsReadOnly="True"
                               Text="{Binding TagStartTimeText, Mode=OneWay}"/>
                      <Button Grid.Column="1"
                              Classes="action-button"
                              Command="{Binding UseCurrentFrameForTagStartCommand}"
                              Content="Текущий"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBox Classes="event-type-input"
                               Watermark="Конец"
                               IsReadOnly="True"
                               Text="{Binding TagEndTimeText, Mode=OneWay}"/>
                      <Button Grid.Column="1"
                              Classes="action-button"
                              Command="{Binding UseCurrentFrameForTagEndCommand}"
                              Content="Текущий"/>
                    </Grid>
                    <ComboBox ItemsSource="{Binding EventTeamSides}"
                              SelectedItem="{Binding TagTeamSide, Mode=TwoWay}"/>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding TagPlayer}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Игрок"
                                 IsVisible="{Binding TagPlayer, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding TagPeriod}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Период"
                                 IsVisible="{Binding TagPeriod, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                    <Grid>
                      <TextBox Classes="event-type-input"
                               Text="{Binding TagNotes}"/>
                      <TextBlock Classes="input-placeholder"
                                 Text="Заметки"
                                 IsVisible="{Binding TagNotes, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                  </StackPanel>

                  <Grid Grid.Row="2"
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding AddTagCommand}"
                            Content="Сохранить"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            IsVisible="{Binding IsEditingTagEvent}"
                            Command="{Binding DeleteSelectedTagCommand}"
                            IsEnabled="{Binding CanDeleteEditedTagEvent}"
                            Content="Удалить"/>
                    <Button Grid.Column="2"
                            Classes="action-button"
                            Command="{Binding CloseTagEventEditorCommand}"
                            Content="Закрыть"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </Border>
      <GridSplitter x:Name="AnalysisPanelSplitter" Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="3"
                    Width="6"
                    Background="#283244"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"
                    PointerEntered="OnWorkspaceSplitterPointerEntered"
                    PointerExited="OnWorkspaceSplitterPointerExited"
                    IsVisible="{Binding IsAnalysisPanelVisible}"/>

      <Border x:Name="AnalysisPanel" Grid.Row="0"
              Grid.RowSpan="3"
              Grid.Column="4"
              Classes="panel"
              Padding="0"
              IsVisible="{Binding IsAnalysisPanelVisible}">
        <Grid RowDefinitions="Auto,Auto,*">
          <Border Grid.Row="0"
                  Classes="panel-window-header"
                  Cursor="SizeAll"
                  Tag="Analysis"
                  PointerPressed="OnPanelHeaderPointerPressed">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Classes="section-title"
                         Text="Клипы"
                         VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                <Button Classes="panel-window-button" Tag="Analysis:Minimize" Click="OnPanelWindowControlClick" Content="−"/>
                <Button Classes="panel-window-button" Tag="Analysis:Maximize" Click="OnPanelWindowControlClick" Content="□"/>
                <Button Classes="panel-window-button close-button" Tag="Analysis:Close" Click="OnPanelWindowControlClick" Content="×"/>
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" Classes="panel-tabs" IsVisible="False">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
              <ToggleButton Grid.Column="0"
                            Classes="tab-button"
                            IsChecked="{Binding IsPlaylistsTabSelected}"
                            Command="{Binding SelectRightPanelTabCommand}"
                            CommandParameter="Playlists"
                            Content="Клипы"/>
              <ToggleButton Grid.Column="1"
                            Classes="tab-button"
                            IsChecked="{Binding IsStatisticsTabSelected}"
                            Command="{Binding SelectRightPanelTabCommand}"
                            CommandParameter="Statistics"
                            Content="Клипы"/>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="2"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True"
                        IsVisible="{Binding IsPlaylistsTabSelected}">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="14"
                  ClipToBounds="True"
                  Margin="18,18,18,18">
              <StackPanel Spacing="4">
                <TextBlock Classes="section-title" Text="Плейлисты"/>
                <TextBlock Classes="section-subtitle" Text="Собирайте подборки из отмеченных событий, открывайте их в плеере и готовьте к экспорту."/>
              </StackPanel>

              <Border Grid.Row="1"
                      Classes="placeholder-card">
                <StackPanel Spacing="10">
  <TextBlock Text="Конструктор подборки"
             FontSize="16"
             FontWeight="SemiBold"/>
  <Grid>
    <TextBox Classes="event-type-input"
             Text="{Binding PlaylistName}"/>
    <TextBlock Classes="input-placeholder"
               Text="Название плейлиста"
               IsVisible="{Binding PlaylistName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
  </Grid>
  <Grid>
    <TextBox Classes="event-type-input"
             Text="{Binding PlaylistDescription}"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             Height="70"/>
    <TextBlock Classes="input-placeholder"
               Text="Описание подборки"
               VerticalAlignment="Top"
               Margin="12,12,12,12"
               IsVisible="{Binding PlaylistDescription, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
  </Grid>
  <Button Classes="action-button"
          Command="{Binding CreatePlaylistCommand}"
          IsEnabled="{Binding CanCreatePlaylist}"
          Content="Создать плейлист"/>
</StackPanel>
              </Border>

              <Border Grid.Row="2"
                      Classes="placeholder-card">
                <StackPanel Spacing="10">
                  <TextBlock Text="Сохраненные плейлисты"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                  <ListBox Classes="event-type-list"
                           ItemsSource="{Binding Playlists}"
                           SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                           MaxHeight="220">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="items:PlaylistSummaryItemViewModel">
                        <Border Background="#162238"
                                BorderBrush="#2B3C59"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="#F7FAFF"/>
                            <TextBlock Text="{Binding Description}"
                                       Foreground="#C9D7EB"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>
                            <TextBlock Text="{Binding UpdatedAtText}"
                                       Foreground="#8FA3BF"
                                       FontSize="12"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding OpenSelectedPlaylistCommand}"
                            IsEnabled="{Binding CanOpenSelectedPlaylist}"
                            Content="Открыть"/>
                    <Button Grid.Column="1"
                            Classes="action-button"
                            Command="{Binding DeleteSelectedPlaylistCommand}"
                            IsEnabled="{Binding CanDeleteSelectedPlaylist}"
                            Content="Удалить"/>
                    <Button Grid.Column="2"
                            Classes="action-button"
                            Command="{Binding OpenExportDialogForPlaylistCommand}"
                            IsEnabled="{Binding CanPlayActivePlaylist}"
                            Content="Экспорт"/>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Grid.Row="3"
                      Classes="placeholder-card">
                <Grid RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="10">
                  <TextBlock Text="Текущая подборка"
                             FontSize="16"
                             FontWeight="SemiBold"/>
                  <TextBlock Grid.Row="1"
                             Text="{Binding ClipSummary}"
                             Foreground="#AAB9CF"/>

                  <ListBox Grid.Row="2"
                           Classes="event-type-list"
                           ItemsSource="{Binding PlaylistItems}"
                           SelectedItem="{Binding SelectedPlaylistItem, Mode=TwoWay}"
                           IsVisible="{Binding HasPlaylistItems}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="items:PlaylistClipItemViewModel">
                        <Border Background="#162238"
                                BorderBrush="#2B3C59"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10">
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding Label}"
                                         FontWeight="SemiBold"
                                         Foreground="#F7FAFF"/>
                              <TextBlock Text="{Binding FrameRangeText}"
                                         Foreground="#C9D7EB"/>
                              <TextBlock Text="{Binding Player}"
                                         Foreground="#8FA3BF"
                                         FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="event-eye-button"
                                    Command="{Binding #RootWindow.DataContext.SeekToPlaylistItemCommand}"
                                    CommandParameter="{Binding}">
                              <TextBlock Text="▶"
                                         FontSize="12"/>
                            </Button>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <TextBlock Grid.Row="2"
                             Text="Пока нет открытого плейлиста."
                             Foreground="#AAB9CF"
                             IsVisible="{Binding HasNoPlaylistItems}"/>

                  <Grid Grid.Row="3"
                        ColumnDefinitions="Auto">
                    <Button Grid.Column="0"
                            Classes="action-button"
                            Command="{Binding PlayActivePlaylistCommand}"
                            IsEnabled="{Binding CanPlayActivePlaylist}"
                            Content="Воспроизвести"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </ScrollViewer>

          <ScrollViewer Grid.Row="2"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True"
                        IsVisible="{Binding IsStatisticsTabSelected}">
            <Grid RowDefinitions="Auto,*"
                  ClipToBounds="True">
              <Border Grid.Row="0" Classes="stats-header-card">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,*,Auto" ColumnSpacing="12">
                    <Border Classes="stats-logo-placeholder"/>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <TextBlock Text="ХОЗЯЕВА"
                                 FontSize="14"
                                 Foreground="#AAB9CF"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding HomeTeamDisplayName}"
                                 FontSize="12"
                                 Foreground="#8FA3BF"
                                 MaxWidth="120"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding HomeScore}"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <TextBlock Grid.Column="3"
                               Text="-"
                               VerticalAlignment="Center"
                               FontSize="20"
                               Foreground="#AAB9CF"/>
                    <TextBlock Grid.Column="4"
                               Text="{Binding AwayScore}"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFF"/>
                    <StackPanel Grid.Column="5"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="2">
                      <TextBlock Text="ГОСТИ"
                                 HorizontalAlignment="Right"
                                 FontSize="14"
                                 Foreground="#AAB9CF"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding AwayTeamDisplayName}"
                                 HorizontalAlignment="Right"
                                 FontSize="12"
                                 Foreground="#8FA3BF"
                                 MaxWidth="120"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Border Grid.Column="6" Classes="stats-logo-placeholder"/>
                  </Grid>
                </Border>

              <ItemsControl Grid.Row="1"
                            ItemsSource="{Binding StatisticsItems}"
                            Margin="18,18,18,18">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="items:StatisticsBarItemViewModel">
                    <StackPanel Spacing="8" Margin="0,0,0,16">
                      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <TextBlock Text="{Binding HomeCount}"
                                   Foreground="#8FA3BF"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   HorizontalAlignment="Center"
                                   Foreground="#AAB9CF"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AwayCount}"
                                   Foreground="#8FA3BF"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                      </Grid>
                      <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">
                        <Border Grid.Column="0" Classes="stats-bar-track">
                          <ProgressBar Classes="stats-bar-home"
                                       Maximum="{Binding MaxCount}"
                                       Value="{Binding HomeCount}"
                                       FlowDirection="RightToLeft"/>
                        </Border>
                        <Border Grid.Column="2" Classes="stats-bar-track">
                          <ProgressBar Classes="stats-bar-away"
                                       Maximum="{Binding MaxCount}"
                                       Value="{Binding AwayCount}"/>
                        </Border>
                      </Grid>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>
      <GridSplitter x:Name="TimelinePanelSplitter" Grid.Row="1"
                    Grid.Column="0"
                    Height="6"
                    Background="#283244"
                    ResizeDirection="Rows"
                    PointerEntered="OnWorkspaceSplitterPointerEntered"
                    PointerExited="OnWorkspaceSplitterPointerExited"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

      <Border x:Name="TimelinePanel"
              Grid.Row="2"
              Grid.Column="0"
              Classes="panel"
              Padding="0"
              ClipToBounds="True"
              IsVisible="{Binding IsTimelineVisible}">
        <Grid RowDefinitions="Auto,*"
              Background="#1A1A1A"
              ClipToBounds="True">
          <Border Grid.Row="0"
                  Classes="panel-window-header"
                  Cursor="SizeAll"
                  Tag="Timeline"
                  PointerPressed="OnPanelHeaderPointerPressed">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          VerticalAlignment="Center">
                <TextBlock Classes="section-title"
                           VerticalAlignment="Center"
                           Text="Таймлайн"/>
                <TextBlock Text="{Binding TimelineHeaderTimeText}"
                           VerticalAlignment="Center"
                           Foreground="#8FA3BF"
                           FontSize="12"/>
              </StackPanel>

              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="4"
                          VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                  <TextBlock Text="Масштаб"
                             Foreground="#FFFFFF"
                             FontSize="13"
                             VerticalAlignment="Center"/>
                  <Border x:Name="TimelineZoomSliderRoot"
                          Width="164"
                          Height="28"
                          Background="#06101A"
                          BorderBrush="#FFFFFF"
                          BorderThickness="2"
                          ClipToBounds="True"
                          SizeChanged="OnTimelineZoomSliderSizeChanged"
                          PointerPressed="OnTimelineZoomSliderPointerPressed"
                          PointerMoved="OnTimelineZoomSliderPointerMoved"
                          PointerReleased="OnTimelineZoomSliderPointerReleased">
                    <Grid Margin="5,0"
                          ClipToBounds="True">
                      <Border Height="10"
                              CornerRadius="0"
                              Background="#073454"
                              VerticalAlignment="Center"/>
                      <Border x:Name="TimelineZoomSliderProgress"
                              Width="0"
                              Height="10"
                              CornerRadius="0"
                              Background="#0087D9"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"/>
                      <Ellipse x:Name="TimelineZoomSliderThumb"
                               Width="20"
                               Height="20"
                               Fill="#0087D9"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                  <TextBlock Text="{Binding TimelineZoomText}"
                             Width="42"
                             Foreground="#FFFFFF"
                             FontSize="13"
                             VerticalAlignment="Center"/>
                </StackPanel>

                <ToggleButton x:Name="TimelineFilterButton"
                              Width="155.5"
                              Height="30"
                              Margin="0,0,8,0"
                              VerticalAlignment="Center"
                              CornerRadius="4"
                              Background="#1E2939"
                              BorderBrush="#1E2939"
                              BorderThickness="1"
                              IsChecked="{Binding IsTimelineFilterPopupOpen}">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        Margin="12,0"
                        VerticalAlignment="Center">
                    <Canvas Width="14"
                            Height="14"
                            VerticalAlignment="Center">
                      <Path Data="M7.99964 17c-0.00009 0.18583 0.05161 0.36801 0.14929 0.5261 0.09768 0.15809 0.23748 0.28583 0.40371 0.3689l2 1c0.1525 0.0762 0.32194 0.11215 0.49224 0.10444 0.1703-0.00771 0.3358-0.05883 0.48079-0.14851 0.14498-0.08968 0.26464-0.21493 0.34759-0.36386 0.08296-0.14893 0.12646-0.3166 0.12638-0.48707l0-7c0.00022-0.49562 0.18446-0.9735 0.517-1.341l7.223-7.989c0.12946-0.14344 0.21459-0.32132 0.2451-0.51212 0.03051-0.1908 0.00509-0.38635-0.0732-0.56301-0.07828-0.17666-0.20606-0.32685-0.36789-0.43242-0.16183-0.10557-0.35079-0.162-0.54401-0.16245l-18 0c-0.19339 0.00007-0.38262 0.05622-0.54475 0.16164-0.16213 0.10542-0.29022 0.25559-0.36875 0.43232-0.07852 0.17673-0.10412 0.37245-0.07368 0.56343 0.03044 0.19098 0.1156 0.36904 0.24518 0.51261l7.225 7.989c0.33254 0.3675 0.51678 0.84538 0.517 1.341l0 6z"
                            Stroke="#FFFFFF"
                            StrokeThickness="1.1666666"
                            StrokeLineCap="Round"
                            StrokeJoin="Round"
                            Width="11.66508"
                            Height="11.083605"
                            Stretch="Fill">
                        <Path.RenderTransform>
                          <TranslateTransform X="1.1669" Y="1.75"/>
                        </Path.RenderTransform>
                      </Path>
                    </Canvas>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TimelineFilterButtonText}"
                               Foreground="#FFFFFF"
                               FontSize="14"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="4,0"/>
                    <Canvas Grid.Column="2"
                            Width="12"
                            Height="12"
                            VerticalAlignment="Center">
                      <Path Data="M0 0l6 6 6-6"
                            Stroke="#FFFFFF"
                            StrokeThickness="1"
                            StrokeLineCap="Round"
                            StrokeJoin="Round"
                            Width="6"
                            Height="3"
                            Stretch="Fill">
                        <Path.RenderTransform>
                          <TranslateTransform X="3" Y="4.5"/>
                        </Path.RenderTransform>
                      </Path>
                    </Canvas>
                  </Grid>
                </ToggleButton>

                <Button Classes="panel-window-button" Tag="Timeline:Minimize" Click="OnPanelWindowControlClick" Content="−"/>
                <Button Classes="panel-window-button" Tag="Timeline:Maximize" Click="OnPanelWindowControlClick" Content="□"/>
                <Button Classes="panel-window-button close-button" Tag="Timeline:Close" Click="OnPanelWindowControlClick" Content="×"/>
              </StackPanel>

              <Popup PlacementTarget="{Binding #TimelineFilterButton}"
                     IsOpen="{Binding IsTimelineFilterPopupOpen}"
                     Placement="Bottom"
                     HorizontalOffset="0"
                     VerticalOffset="8">
                <Border Background="#252525"
                        BorderBrush="#1E2939"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Width="220"
                        MaxHeight="260">
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding TimelineFilters}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="10"
                                Height="32">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{Binding ColorHex}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       Foreground="#D1D5DC"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="2"
                                      IsChecked="{Binding IsVisible}"
                                      VerticalAlignment="Center"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        ClipToBounds="True">
            <Grid ColumnDefinitions="128,*"
                  Background="#1A1A1A">
              <Grid Grid.Column="0"
                    Background="#1A1A1A">
                <Grid RowDefinitions="24,*">
                  <Border Grid.Row="0"
                          Background="#252525"
                          BorderBrush="#1E2939"
                          BorderThickness="0,0,1,1">
                    <TextBlock Text="Время"
                               Margin="16,1,0,0"
                               Foreground="#6A7282"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                  </Border>
                  <ItemsControl Grid.Row="1"
                                ItemsSource="{Binding TimelineRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="items:TimelineRowItemViewModel">
                        <Border Height="40"
                                Background="#1A1A1A"
                                BorderBrush="#1E293980"
                                BorderThickness="0,0,1,1">
                          <StackPanel Orientation="Horizontal"
                                      Spacing="8"
                                      VerticalAlignment="Center"
                                      Margin="16,0,0,0">
                            <Border Width="8"
                                    Height="8"
                                    CornerRadius="33554400"
                                    Background="{Binding ColorHex}"/>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#D1D5DC"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Grid>

              <ScrollViewer x:Name="TimelineHorizontalScrollViewer" Grid.Column="1"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Disabled"
                            ClipToBounds="True"
                            SizeChanged="OnTimelineViewportSizeChanged"
                            ScrollChanged="OnTimelineHorizontalScrollChanged"
                            PointerPressed="OnTimelinePanPointerPressed"
                            PointerMoved="OnTimelinePanPointerMoved"
                            PointerReleased="OnTimelinePanPointerReleased"
                            PointerWheelChanged="OnTimelinePointerWheelChanged">
                <Grid x:Name="TimelineCanvasRoot"
                      Width="{Binding TimelineCanvasWidth}"
                      HorizontalAlignment="Left"
                      Background="#1A1A1A"
                      PointerPressed="OnTimelineSeekPointerPressed"
                      PointerMoved="OnTimelineSeekPointerMoved"
                      PointerReleased="OnTimelineSeekPointerReleased">
                  <Grid RowDefinitions="24,*">
                    <Border Grid.Row="0"
                            Background="#252525"
                            BorderBrush="#1E2939"
                            BorderThickness="0,0,0,1"/>

                    <Canvas Grid.Row="0"
                            Width="{Binding TimelineCanvasWidth}"
                            Height="24"
                            IsHitTestVisible="False"
                            ZIndex="4">
                      <Path Width="14"
                            Height="9"
                            Fill="#FB2C36"
                            Stretch="Fill"
                            Data="M 0 0 L 14 0 L 7 9 Z"
                            Canvas.Left="{Binding TimelineCurrentLineLeft}">
                        <Path.RenderTransform>
                          <TranslateTransform X="-7" Y="14"/>
                        </Path.RenderTransform>
                      </Path>
                    </Canvas>

                    <ItemsControl Grid.Row="0"
                                  Classes="timeline-ticks"
                                  ItemsSource="{Binding TimelineTicks}"
                                  IsHitTestVisible="False">
                      <ItemsControl.Styles>
                        <Style Selector="ItemsControl.timeline-ticks > ContentPresenter">
                          <Setter Property="Canvas.Left" Value="{ReflectionBinding DataContext.Left, RelativeSource={RelativeSource Self}}"/>
                        </Style>
                      </ItemsControl.Styles>
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <Canvas Height="24"
                                  Width="{Binding DataContext.TimelineCanvasWidth, ElementName=RootWindow}"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="items:TimelineTickItemViewModel">
                          <Grid Width="52"
                                Height="24"
                                IsHitTestVisible="False">
                            <Border Width="1"
                                    Height="8"
                                    Background="#364153"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding Label}"
                                       Foreground="#E2E8F0"
                                       FontSize="13"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="4,0,0,0"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding TimelineRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="items:TimelineRowItemViewModel">
                          <Grid Height="40"
                                Background="#1A1A1A"
                                ClipToBounds="True">
                            <Border BorderBrush="#1E293980"
                                    BorderThickness="0,0,0,1"/>
                            <Canvas Height="40"
                                    ClipToBounds="True">
                              <ItemsControl Classes="timeline-grid-lines"
                                            ItemsSource="{Binding DataContext.TimelineTicks, ElementName=RootWindow}"
                                            IsHitTestVisible="False">
                                <ItemsControl.Styles>
                                  <Style Selector="ItemsControl.timeline-grid-lines > ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{ReflectionBinding DataContext.Left, RelativeSource={RelativeSource Self}}"/>
                                  </Style>
                                </ItemsControl.Styles>
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <Canvas Height="40"
                                            Width="{Binding DataContext.TimelineCanvasWidth, ElementName=RootWindow}"/>
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="items:TimelineTickItemViewModel">
                                    <Border Width="1"
                                            Height="39"
                                            Background="#1E29394D"/>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>

                              <Border Width="2"
                                      Height="39"
                                      Background="#FB2C36"
                                      IsHitTestVisible="False"
                                      Canvas.Left="{Binding DataContext.TimelineCurrentLineLeft, ElementName=RootWindow}"/>

                              <ItemsControl Classes="timeline-segments"
                                            ItemsSource="{Binding Segments}">
                                <ItemsControl.Styles>
                                  <Style Selector="ItemsControl.timeline-segments > ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{ReflectionBinding DataContext.Left, RelativeSource={RelativeSource Self}}"/>
                                    <Setter Property="Canvas.Top" Value="8"/>
                                  </Style>
                                </ItemsControl.Styles>
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <Canvas Height="40"
                                            Width="{Binding DataContext.TimelineCanvasWidth, ElementName=RootWindow}"/>
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="items:TimelineEventSegmentItemViewModel">
                                    <Border Width="{Binding Width}"
                                            Height="24"
                                            Background="{Binding ColorHex}"
                                            CornerRadius="4"
                                            Opacity="0.8"
                                            Cursor="Hand"
                                            PointerPressed="OnTimelineEventSegmentPointerPressed"/>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </Canvas>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </Grid>
              </ScrollViewer>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border x:Name="BroadcastPanel"
              Classes="panel"
              Padding="0"
              IsVisible="{Binding IsBroadcastPanelVisible}">
        <Grid RowDefinitions="Auto,*"
              ClipToBounds="True">
          <Border Grid.Row="0"
                  Classes="panel-window-header"
                  Cursor="SizeAll"
                  Tag="Broadcast"
                  PointerPressed="OnPanelHeaderPointerPressed">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          VerticalAlignment="Center">
                <TextBlock Classes="section-title"
                           VerticalAlignment="Center"
                           Text="Трансляция"/>
                <TextBlock x:Name="BroadcastStatusText"
                           VerticalAlignment="Center"
                           Foreground="#8FA3BF"
                           FontSize="12"
                           Text="Ожидание камеры"/>
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="4">
                <Button Classes="panel-window-button" Tag="Broadcast:Minimize" Click="OnPanelWindowControlClick" Content="−"/>
                <Button Classes="panel-window-button" Tag="Broadcast:Maximize" Click="OnPanelWindowControlClick" Content="□"/>
                <Button Classes="panel-window-button close-button" Tag="Broadcast:Close" Click="OnPanelWindowControlClick" Content="×"/>
              </StackPanel>
            </Grid>
          </Border>

          <Border x:Name="BroadcastSurfaceHost"
                  Grid.Row="1"
                  Background="#050B14"
                  BorderBrush="#111315"
                  BorderThickness="0"
                  ClipToBounds="True"
                  SizeChanged="OnBroadcastSurfaceSizeChanged">
            <Grid>
              <Grid x:Name="BroadcastVideoPresenter"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Image x:Name="BroadcastPreviewImage"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Stretch="Uniform"
                       IsVisible="False"/>
              </Grid>

              <Border HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="12"
                      Background="#CC050B14"
                      BorderBrush="#334155"
                      BorderThickness="1"
                      CornerRadius="5"
                      Padding="10,7">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <TextBlock Text="LIVE"
                             Foreground="#FF3B3B"
                             FontWeight="Bold"
                             FontSize="12"/>
                  <TextBlock Text="{Binding TimelineCurrentTimeText}"
                             Foreground="#F7FAFF"
                             FontSize="12"
                             FontWeight="SemiBold"/>
                </StackPanel>
              </Border>

              <Border HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="12"
                      Background="#DD050B14"
                      BorderBrush="#334155"
                      BorderThickness="1"
                      CornerRadius="7"
                      Padding="8">
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                  <Button Classes="broadcast-record-button"
                          IsEnabled="{Binding CanToggleBroadcastLive}"
                          Click="OnBroadcastLiveButtonClick"
                          ToolTip.Tip="{Binding BroadcastLiveButtonText}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                      <TextBlock Text="{Binding BroadcastLiveGlyph}"
                                 FontSize="15"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding BroadcastLiveButtonText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"/>
                    </StackPanel>
                  </Button>
                  <Button Classes="broadcast-record-button"
                          IsEnabled="{Binding CanUseBroadcastRecording}"
                          Click="OnBroadcastRecordingButtonClick"
                          ToolTip.Tip="{Binding BroadcastRecordingButtonText}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                      <TextBlock Text="{Binding BroadcastRecordingGlyph}"
                                 Foreground="#FF3B3B"
                                 FontSize="16"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding BroadcastRecordingButtonText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"/>
                    </StackPanel>
                  </Button>
                  <Button Classes="broadcast-record-button"
                          IsEnabled="{Binding CanSyncBroadcastLive}"
                          Click="OnBroadcastSyncButtonClick"
                          ToolTip.Tip="Синхронизировать трансляцию с реальным временем">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                      <TextBlock Text="↻"
                                 FontSize="15"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding BroadcastSyncButtonText}"
                                 FontSize="13"
                                 FontWeight="SemiBold"/>
                    </StackPanel>
                  </Button>
                  <TextBlock Text="{Binding BroadcastRecordingStatusText}"
                             VerticalAlignment="Center"
                             Foreground="#C4D3EA"
                             FontSize="12"/>
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Button x:Name="EventsSplitterAddWindowButton"
              Classes="workspace-edge-add-button"
              IsVisible="False"
              Content="+"
              Click="OnWorkspaceEdgeAddWindowClick"
              PointerEntered="OnWorkspaceAddButtonPointerEntered"
              PointerExited="OnWorkspaceAddButtonPointerExited"
              ToolTip.Tip="Добавить окно"/>

      <Button x:Name="AnalysisSplitterAddWindowButton"
              Classes="workspace-edge-add-button"
              IsVisible="False"
              Content="+"
              Click="OnWorkspaceEdgeAddWindowClick"
              PointerEntered="OnWorkspaceAddButtonPointerEntered"
              PointerExited="OnWorkspaceAddButtonPointerExited"
              ToolTip.Tip="Добавить окно"/>

      <Button x:Name="TimelineSplitterAddWindowButton"
              Classes="workspace-edge-add-button"
              IsVisible="False"
              Content="+"
              Click="OnWorkspaceEdgeAddWindowClick"
              PointerEntered="OnWorkspaceAddButtonPointerEntered"
              PointerExited="OnWorkspaceAddButtonPointerExited"
              ToolTip.Tip="Добавить окно"/>

      <Border x:Name="SlotPlaceholder0"
              Classes="workspace-empty-slot"
              IsVisible="False">
        <Grid>
          <Button Classes="panel-window-button close-button"
                  Tag="0"
                  Click="OnCloseEmptySlotClick"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  ToolTip.Tip="Убрать пустое окно"
                  Content="×"/>
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="18">
            <StackPanel Spacing="6">
              <TextBlock Text="Создать вид"
                         HorizontalAlignment="Center"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#F5F7FB"/>
              <TextBlock Text="Выберите сущность для этого окна"
                         HorizontalAlignment="Center"
                         Foreground="#8FA3BF"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Center">
              <Button Classes="workspace-entity-button" Tag="0:Player" Click="OnCreateSlotEntityClick" Content="Плеер" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="0:Timeline" Click="OnCreateSlotEntityClick" Content="Таймлайн" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="0:EventsClips" Click="OnCreateSlotEntityClick" Content="События" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="0:Statistics" Click="OnCreateSlotEntityClick" Content="Клипы" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="0:Broadcast" Click="OnCreateSlotEntityClick" Content="Трансляция" Margin="4" IsVisible="{Binding IsBroadcastEntityAvailable}"/>
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Border x:Name="SlotPlaceholder1"
              Classes="workspace-empty-slot"
              IsVisible="False">
        <Grid>
          <Button Classes="panel-window-button close-button"
                  Tag="1"
                  Click="OnCloseEmptySlotClick"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  ToolTip.Tip="Убрать пустое окно"
                  Content="×"/>
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="18">
            <StackPanel Spacing="6">
              <TextBlock Text="Создать вид"
                         HorizontalAlignment="Center"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#F5F7FB"/>
              <TextBlock Text="Выберите сущность для этого окна"
                         HorizontalAlignment="Center"
                         Foreground="#8FA3BF"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Center">
              <Button Classes="workspace-entity-button" Tag="1:Player" Click="OnCreateSlotEntityClick" Content="Плеер" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="1:Timeline" Click="OnCreateSlotEntityClick" Content="Таймлайн" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="1:EventsClips" Click="OnCreateSlotEntityClick" Content="События" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="1:Statistics" Click="OnCreateSlotEntityClick" Content="Клипы" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="1:Broadcast" Click="OnCreateSlotEntityClick" Content="Трансляция" Margin="4" IsVisible="{Binding IsBroadcastEntityAvailable}"/>
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Border x:Name="SlotPlaceholder2"
              Classes="workspace-empty-slot"
              IsVisible="False">
        <Grid>
          <Button Classes="panel-window-button close-button"
                  Tag="2"
                  Click="OnCloseEmptySlotClick"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  ToolTip.Tip="Убрать пустое окно"
                  Content="×"/>
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="18">
            <StackPanel Spacing="6">
              <TextBlock Text="Создать вид"
                         HorizontalAlignment="Center"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#F5F7FB"/>
              <TextBlock Text="Выберите сущность для этого окна"
                         HorizontalAlignment="Center"
                         Foreground="#8FA3BF"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Center">
              <Button Classes="workspace-entity-button" Tag="2:Player" Click="OnCreateSlotEntityClick" Content="Плеер" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="2:Timeline" Click="OnCreateSlotEntityClick" Content="Таймлайн" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="2:EventsClips" Click="OnCreateSlotEntityClick" Content="События" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="2:Statistics" Click="OnCreateSlotEntityClick" Content="Клипы" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="2:Broadcast" Click="OnCreateSlotEntityClick" Content="Трансляция" Margin="4" IsVisible="{Binding IsBroadcastEntityAvailable}"/>
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Border x:Name="SlotPlaceholder3"
              Classes="workspace-empty-slot"
              IsVisible="False">
        <Grid>
          <Button Classes="panel-window-button close-button"
                  Tag="3"
                  Click="OnCloseEmptySlotClick"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  ToolTip.Tip="Убрать пустое окно"
                  Content="×"/>
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="18">
            <StackPanel Spacing="6">
              <TextBlock Text="Создать вид"
                         HorizontalAlignment="Center"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#F5F7FB"/>
              <TextBlock Text="Выберите сущность для этого окна"
                         HorizontalAlignment="Center"
                         Foreground="#8FA3BF"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Center">
              <Button Classes="workspace-entity-button" Tag="3:Player" Click="OnCreateSlotEntityClick" Content="Плеер" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="3:Timeline" Click="OnCreateSlotEntityClick" Content="Таймлайн" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="3:EventsClips" Click="OnCreateSlotEntityClick" Content="События" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="3:Statistics" Click="OnCreateSlotEntityClick" Content="Клипы" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="3:Broadcast" Click="OnCreateSlotEntityClick" Content="Трансляция" Margin="4" IsVisible="{Binding IsBroadcastEntityAvailable}"/>
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Border x:Name="SlotPlaceholder4"
              Classes="workspace-empty-slot"
              IsVisible="False">
        <Grid>
          <Button Classes="panel-window-button close-button"
                  Tag="4"
                  Click="OnCloseEmptySlotClick"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  ToolTip.Tip="Убрать пустое окно"
                  Content="×"/>
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="18">
            <StackPanel Spacing="6">
              <TextBlock Text="Создать вид"
                         HorizontalAlignment="Center"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#F5F7FB"/>
              <TextBlock Text="Выберите сущность для этого окна"
                         HorizontalAlignment="Center"
                         Foreground="#8FA3BF"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Center">
              <Button Classes="workspace-entity-button" Tag="4:Player" Click="OnCreateSlotEntityClick" Content="Плеер" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="4:Timeline" Click="OnCreateSlotEntityClick" Content="Таймлайн" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="4:EventsClips" Click="OnCreateSlotEntityClick" Content="События" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="4:Statistics" Click="OnCreateSlotEntityClick" Content="Клипы" Margin="4"/>
              <Button Classes="workspace-entity-button" Tag="4:Broadcast" Click="OnCreateSlotEntityClick" Content="Трансляция" Margin="4" IsVisible="{Binding IsBroadcastEntityAvailable}"/>
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>
    <Border Grid.RowSpan="3"
            Grid.ColumnSpan="5"
            Classes="startup-screen-overlay"
            IsVisible="{Binding IsStartupScreenVisible}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="startup-launcher"
                Width="896"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,*">
            <Border Classes="startup-header">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Classes="startup-title"
                             Text="Добро пожаловать в Hockey Video Analyzer"/>
                  <TextBlock Classes="startup-subtitle"
                             Text="Выберите действие для начала работы"/>
                </StackPanel>

                <Button x:Name="StartupCloseButton"
                        Grid.Column="1"
                        Classes="startup-close-button"
                        Command="{Binding CloseStartupScreenCommand}"
                        IsEnabled="{Binding CanCloseStartupScreen}"
                        Content="✕"/>
              </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="24"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="32">
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="16">
                <Button x:Name="StartupPrimaryButton"
                        Classes="startup-action-card"
                        Command="{Binding OpenNewProjectDialogCommand}">
                  <Border Classes="startup-action-surface startup-action-surface-primary"
                          BorderBrush="#4C8DFF">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2B4666" Offset="0"/>
                        <GradientStop Color="#213650" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="33.6,17.6,17.6,17.6">
                      <Border Classes="startup-action-icon-shell"
                              Background="#30527D">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#81C3FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="+"/>
                      </Border>

                      <StackPanel Margin="0,16,56,0"
                                  VerticalAlignment="Top"
                                  Spacing="8">
                        <TextBlock Classes="startup-action-title"
                                   Text="Новый проект"/>
                        <TextBlock Classes="startup-action-subtitle"
                                   Text="Создайте новый проект и импортируйте видео матча для анализа"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>

                <Button Grid.Column="1"
                        Classes="startup-action-card"
                        Command="{Binding OpenProjectPickerCommand}">
                  <Border Classes="startup-action-surface startup-action-surface-secondary"
                          BorderBrush="#B56BFF">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#43295A" Offset="0"/>
                        <GradientStop Color="#311E42" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="33.6,17.6,17.6,17.6">
                      <Border Classes="startup-action-icon-shell"
                              Background="#5A3680">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#E0B5FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="⤴"/>
                      </Border>

                      <StackPanel Margin="0,26,56,0"
                                  VerticalAlignment="Top"
                                  Spacing="8">
                        <TextBlock Classes="startup-action-title"
                                   Text="Открыть проект"/>
                        <TextBlock Classes="startup-action-subtitle"
                                   Text="Продолжите работу над существующим проектом"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </Grid>

              <Grid Grid.Row="1"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="16">
                <Grid>
                  <TextBlock Classes="startup-section-title"
                             Text="НЕДАВНИЕ ПРОЕКТЫ"/>
                </Grid>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding RecentProjects}"
                              IsVisible="{Binding HasRecentProjects}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="16"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="items:RecentProjectItemViewModel">
                      <Button Classes="startup-recent-card-button"
                              Command="{Binding #RootWindow.DataContext.OpenRecentProjectCommand}"
                              CommandParameter="{Binding}">
                        <Border Classes="recent-project-card">
                          <Grid RowDefinitions="Auto,*">
                            <Border Classes="recent-project-preview">
                              <Grid>
                                <Border Classes="recent-project-badge">
                                  <TextBlock Classes="recent-project-badge-text"
                                             Text="{Binding Matchup}"/>
                                </Border>
                              </Grid>
                            </Border>

                            <StackPanel Grid.Row="1"
                                        Margin="12"
                                        Spacing="4">
                              <TextBlock Classes="recent-project-title"
                                         Text="{Binding Name}"/>
                              <TextBlock Classes="recent-project-subtitle"
                                         MaxLines="2"
                                         Text="{Binding Summary}"/>
                              <TextBlock Classes="recent-project-meta"
                                         Margin="0,4,0,0"
                                         Text="{Binding UpdatedAtText}"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="1"
                        Classes="startup-empty-state"
                        IsVisible="{Binding HasNoRecentProjects}">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="recent-project-title"
                               Text="Пока нет проектов"/>
                    <TextBlock Classes="recent-project-subtitle"
                               Text="Создайте первый проект, и он появится здесь для быстрого запуска."/>
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </Border>

        <Border Classes="editor-overlay"
                IsVisible="{Binding IsProjectPickerOpen}">
          <Grid HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Classes="new-project-dialog"
                    Width="680"
                    MaxWidth="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <Grid RowDefinitions="Auto,*,Auto"
                    MaxHeight="620">
                <Border Background="#2F2F32"
                        BorderBrush="#4C566B"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0"
                        Padding="24,20">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="dialog-title"
                                 Text="Открыть проект"/>
                      <TextBlock Classes="dialog-subtitle"
                                 Text="Выберите проект из списка"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="startup-close-button"
                            Command="{Binding CloseProjectPickerCommand}"
                            Content="✕"/>
                  </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="24"
                        Background="#252528">
                  <Grid>
                    <ListBox ItemsSource="{Binding ProjectPickerItems}"
                             SelectedItem="{Binding SelectedRecentProject, Mode=TwoWay}"
                             IsVisible="{Binding HasProjectPickerItems}"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             BorderThickness="0">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="items:RecentProjectItemViewModel">
                          <Border Background="#1A2435"
                                  BorderBrush="#34425A"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="14"
                                  Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="14">
                              <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#F5F7FB"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Matchup}"
                                           Foreground="#C9D7EB"
                                           FontSize="13"/>
                                <TextBlock Text="{Binding Summary}"
                                           Foreground="#8FA3BF"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MaxLines="2"/>
                              </StackPanel>
                              <TextBlock Grid.Column="1"
                                         Text="{Binding UpdatedAtText}"
                                         Foreground="#7E8A9A"
                                         FontSize="12"
                                         VerticalAlignment="Top"/>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Classes="startup-empty-state"
                            IsVisible="{Binding HasNoProjectPickerItems}">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="recent-project-title"
                                   Text="Пока нет проектов"/>
                        <TextBlock Classes="recent-project-subtitle"
                                   Text="Создайте первый проект, и он появится в этом списке."/>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="#2F2F32"
                        BorderBrush="#4C566B"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,12,12"
                        Padding="24,16">
                  <Grid ColumnDefinitions="*,Auto,Auto"
                        ColumnSpacing="12">
                    <Button Grid.Column="1"
                            Classes="action-button"
                            Command="{Binding CloseProjectPickerCommand}"
                            Content="Отмена"/>
                    <Button Grid.Column="2"
                            Classes="action-button"
                            Command="{Binding OpenSelectedRecentProjectCommand}"
                            IsEnabled="{Binding CanOpenSelectedRecentProject}"
                            Content="Открыть"/>
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.RowSpan="3"
            Grid.ColumnSpan="5"
            Classes="editor-overlay"
            Width="{Binding Bounds.Width, ElementName=RootWindow}"
            Height="{Binding Bounds.Height, ElementName=RootWindow}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="{Binding IsNewProjectDialogOpen}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="new-project-dialog"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch">
          <Grid RowDefinitions="Auto,*"
                Width="860"
                MaxWidth="860">
            <Border Background="#2F2F32"
                    BorderBrush="#4C566B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="24,22">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="6">
                  <TextBlock Classes="dialog-title"
                             Text="Создать новый проект"/>
                  <TextBlock Classes="dialog-subtitle"
                             Text="Введите информацию о новом проекте"/>
                </StackPanel>
                <Button x:Name="NewProjectCloseButton"
                        Grid.Column="1"
                        Classes="player-control-button"
                        Command="{Binding CloseNewProjectDialogCommand}"
                        Content="X"
                        VerticalAlignment="Top"/>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#2F2F32"
                    CornerRadius="0,0,12,12"
                    Padding="0">
              <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="22"
                    Margin="24">
                <StackPanel Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="Название проекта *"/>
                  <Border Classes="project-form-shell single-line">
                    <Grid>
                      <TextBox Classes="project-form-plain-input single-line"
                               Text="{Binding NewProjectName}"/>
                      <TextBlock Classes="project-input-placeholder"
                                 Text="Например: СКА vs ЦСКА 15.02.2024"
                                 Foreground="#8FA3BF"
                                 Opacity="1"
                                 IsVisible="{Binding NewProjectName, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                    </Grid>
                  </Border>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#171B22"
                        BorderBrush="#3B4658"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <CheckBox IsChecked="{Binding NewProjectBroadcastMode}"
                              VerticalAlignment="Top"/>
                    <StackPanel Grid.Column="1"
                                Spacing="4">
                      <TextBlock Classes="form-label"
                                 Text="Режим трансляции"/>
                      <TextBlock Classes="dialog-subtitle"
                                 Text="Проект для live-разметки: появится отдельное окно трансляции, а таймлайн будет идти от текущего live-времени."/>
                    </StackPanel>
                  </Grid>
                </Border>

                <StackPanel Grid.Row="2"
                            Spacing="10">
                  <TextBlock Classes="form-label"
                             Text="{Binding NewProjectVideoLabelText}"/>
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <Border Classes="project-form-shell single-line">
                      <Grid>
                        <TextBox Classes="project-form-plain-input single-line"
                                 Text="{Binding NewProjectVideoPath}"/>
                        <TextBlock Classes="project-input-placeholder"
                                   Text="{Binding NewProjectVideoPlaceholderText}"
                                   Foreground="#8FA3BF"
                                   Opacity="1"
                                   IsVisible="{Binding NewProjectVideoPath, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                      </Grid>
                    </Border>
                    <Button Grid.Column="1"
                            Classes="dialog-secondary-button"
                            Click="OnBrowseNewProjectVideoClick"
                            Content="Выбрать"/>
                  </Grid>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Spacing="12">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="form-label"
                               Text="Схема расположения окон"/>
                    <TextBlock Classes="dialog-subtitle"
                               Text="Выберите стартовую сетку проекта. После этого любой слот можно заменить на нужную сущность."/>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*,*"
                        RowDefinitions="Auto,Auto,Auto"
                        ColumnSpacing="12"
                        RowSpacing="12">
                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Classes="layout-choice-button"
                            Tag="Reference"
                            Click="OnWorkspaceLayoutClick">
                      <StackPanel Spacing="8">
                        <Border Classes="layout-preview">
                          <Grid ColumnDefinitions="2*,*,*"
                                RowDefinitions="*,Auto">
                            <Border Grid.Column="0" Grid.RowSpan="2" BorderBrush="#243FFF" BorderThickness="0,0,2,0"/>
                            <Border Grid.Column="1" Grid.RowSpan="2" BorderBrush="#243FFF" BorderThickness="0,0,2,0"/>
                            <Border Grid.Column="0" Grid.Row="1" Height="2" Classes="layout-preview-line"/>
                          </Grid>
                        </Border>
                        <TextBlock Text="Классическая"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Classes="layout-choice-button"
                            Tag="SplitRows"
                            Click="OnWorkspaceLayoutClick">
                      <StackPanel Spacing="8">
                        <Border Classes="layout-preview">
                          <Grid RowDefinitions="*,*">
                            <Border Grid.Row="0" BorderBrush="#243FFF" BorderThickness="0,0,0,2"/>
                          </Grid>
                        </Border>
                        <TextBlock Text="Две строки"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Row="0"
                            Grid.Column="2"
                            Classes="layout-choice-button"
                            Tag="TopTwoBottom"
                            Click="OnWorkspaceLayoutClick">
                      <StackPanel Spacing="8">
                        <Border Classes="layout-preview">
                          <Grid RowDefinitions="*,*"
                                ColumnDefinitions="*,*">
                            <Border Grid.Row="0" Grid.Column="0" BorderBrush="#243FFF" BorderThickness="0,0,2,2"/>
                            <Border Grid.Row="0" Grid.Column="1" BorderBrush="#243FFF" BorderThickness="0,0,0,2"/>
                          </Grid>
                        </Border>
                        <TextBlock Text="Два сверху"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="0"
                            Classes="layout-choice-button"
                            Tag="FourGrid"
                            Click="OnWorkspaceLayoutClick">
                      <StackPanel Spacing="8">
                        <Border Classes="layout-preview">
                          <Grid RowDefinitions="*,*"
                                ColumnDefinitions="*,*">
                            <Border Grid.Column="0" BorderBrush="#243FFF" BorderThickness="0,0,2,0"/>
                            <Border Grid.Row="0" BorderBrush="#243FFF" BorderThickness="0,0,0,2"/>
                          </Grid>
                        </Border>
                        <TextBlock Text="Четыре окна"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Classes="layout-choice-button"
                            Tag="SplitColumns"
                            Click="OnWorkspaceLayoutClick">
                      <StackPanel Spacing="8">
                        <Border Classes="layout-preview">
                          <Grid ColumnDefinitions="*,*">
                            <Border Grid.Column="0" BorderBrush="#243FFF" BorderThickness="0,0,2,0"/>
                          </Grid>
                        </Border>
                        <TextBlock Text="Две колонки"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="2"
                            Classes="layout-choice-button"
                            Tag="BottomTwo"
                            Click="OnWorkspaceLayoutClick">
                      <StackPanel Spacing="8">
                        <Border Classes="layout-preview">
                          <Grid RowDefinitions="*,*"
                                ColumnDefinitions="*,*">
                            <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#243FFF" BorderThickness="0,0,0,2"/>
                            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#243FFF" BorderThickness="0,0,2,0"/>
                          </Grid>
                        </Border>
                        <TextBlock Text="Два снизу"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            Classes="layout-choice-button"
                            Tag="FiveWindows"
                            Click="OnWorkspaceLayoutClick">
                      <StackPanel Spacing="8">
                        <Border Classes="layout-preview">
                          <Grid RowDefinitions="*,*"
                                ColumnDefinitions="*,*,*">
                            <Border Grid.Row="0" Grid.Column="0" BorderBrush="#243FFF" BorderThickness="0,0,2,2"/>
                            <Border Grid.Row="0" Grid.Column="1" BorderBrush="#243FFF" BorderThickness="0,0,2,2"/>
                            <Border Grid.Row="0" Grid.Column="2" BorderBrush="#243FFF" BorderThickness="0,0,0,2"/>
                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="#243FFF" BorderThickness="0,0,2,0"/>
                          </Grid>
                        </Border>
                        <TextBlock Text="Пять окон"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"/>
                      </StackPanel>
                    </Button>
                  </Grid>
                </StackPanel>

                <Grid Grid.Row="4"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="22">
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="14">
                    <StackPanel Spacing="10">
                      <TextBlock Classes="form-label"
                                 Text="Команда (хозяева)"/>
                      <Border Classes="project-form-shell single-line">
                        <Grid>
                          <TextBox Classes="project-form-plain-input single-line"
                                   Text="{Binding NewProjectHomeTeam}"/>
                          <TextBlock Classes="project-input-placeholder"
                                     Text="Название команды"
                                     Foreground="#8FA3BF"
                                     Opacity="1"
                                     IsVisible="{Binding NewProjectHomeTeam, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                        </Grid>
                      </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="10">
                      <TextBlock Classes="form-label"
                                 Text="Команда (гости)"/>
                      <Border Classes="project-form-shell single-line">
                        <Grid>
                          <TextBox Classes="project-form-plain-input single-line"
                                   Text="{Binding NewProjectAwayTeam}"/>
                          <TextBlock Classes="project-input-placeholder"
                                     Text="Название команды"
                                     Foreground="#8FA3BF"
                                     Opacity="1"
                                     IsVisible="{Binding NewProjectAwayTeam, Converter={StaticResource StringNullOrEmptyToBoolConverter}}"/>
                        </Grid>
                      </Border>
                    </StackPanel>
                  </Grid>

                  <Grid Grid.Row="1"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="14">
                    <Button Grid.Column="0"
                            Classes="dialog-secondary-button"
                            Command="{Binding CloseNewProjectDialogCommand}"
                            Content="Назад"/>
                    <Button Grid.Column="1"
                            Classes="dialog-primary-button"
                            Command="{Binding ContinueNewProjectCommand}"
                            Content="{Binding NewProjectPrimaryButtonText}"/>
                  </Grid>
                </Grid>
              </Grid>
              </ScrollViewer>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>


    <Border Grid.RowSpan="3"
            Grid.ColumnSpan="5"
            Classes="export-window-overlay"
            IsVisible="{Binding IsExportDialogOpen}">
      <Grid HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Classes="export-window-dialog"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,*,Auto">
            <Border Classes="export-window-header">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <TextBlock Classes="export-window-title"
                           VerticalAlignment="Center"
                           Text="Экспорт видео"/>
                <Button x:Name="ExportDialogCloseButton"
                        Grid.Column="1"
                        Classes="startup-close-button"
                        Command="{Binding CloseExportDialogCommand}"
                        IsEnabled="{Binding CanCloseExportDialog}"
                        Content="×"/>
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="24"
                          Spacing="24">
                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Что экспортировать"/>
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                    <ToggleButton Grid.Column="0"
                                  Classes="export-option-button large"
                                  IsChecked="{Binding IsExportAllClipsSelected}"
                                  Command="{Binding SelectExportSourceCommand}"
                                  CommandParameter="AllClips">
                      <StackPanel Spacing="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <Path Data="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z M14.5 2v5.5H20.5"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.67"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"/>
                        <TextBlock FontSize="12"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Text="Все клипы"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Grid.Column="1"
                                  Classes="export-option-button large"
                                  IsChecked="{Binding IsExportPlaylistSelected}"
                                  Command="{Binding SelectExportSourceCommand}"
                                  CommandParameter="Playlist">
                      <StackPanel Spacing="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <Path Data="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z M14.5 2v5.5H20.5"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.67"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"/>
                        <TextBlock FontSize="12"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Text="Плейлист"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Grid.Column="2"
                                  Classes="export-option-button large"
                                  IsChecked="{Binding IsExportFullMatchSelected}"
                                  Command="{Binding SelectExportSourceCommand}"
                                  CommandParameter="FullMatch">
                      <StackPanel Spacing="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <Path Data="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z M14.5 2v5.5H20.5"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.67"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"/>
                        <TextBlock FontSize="12"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Text="Полный матч"/>
                      </StackPanel>
                    </ToggleButton>
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Формат"/>
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                    <ToggleButton Grid.Column="0"
                                  Classes="export-option-button medium"
                                  IsChecked="{Binding IsExportFormatMp4Selected}"
                                  Command="{Binding SelectExportFormatCommand}"
                                  CommandParameter="Mp4"
                                  Content=".MP4"/>
                    <ToggleButton Grid.Column="1"
                                  Classes="export-option-button medium"
                                  IsChecked="{Binding IsExportFormatAviSelected}"
                                  Command="{Binding SelectExportFormatCommand}"
                                  CommandParameter="Avi"
                                  Content=".AVI"/>
                    <ToggleButton Grid.Column="2"
                                  Classes="export-option-button medium"
                                  IsChecked="{Binding IsExportFormatMovSelected}"
                                  Command="{Binding SelectExportFormatCommand}"
                                  CommandParameter="Mov"
                                  Content=".MOV"/>
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Качество"/>
                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                    <ToggleButton Grid.Column="0"
                                  Classes="export-option-button small"
                                  IsChecked="{Binding IsExportQualityLowSelected}"
                                  Command="{Binding SelectExportQualityCommand}"
                                  CommandParameter="Low720p"
                                  Content="Низкое (720p)"/>
                    <ToggleButton Grid.Column="1"
                                  Classes="export-option-button small"
                                  IsChecked="{Binding IsExportQualityMediumSelected}"
                                  Command="{Binding SelectExportQualityCommand}"
                                  CommandParameter="Medium1080p"
                                  Content="Среднее (1080p)"/>
                    <ToggleButton Grid.Column="2"
                                  Classes="export-option-button small"
                                  IsChecked="{Binding IsExportQualityHighSelected}"
                                  Command="{Binding SelectExportQualityCommand}"
                                  CommandParameter="High4K"
                                  Content="Высокое (4K)"/>
                  </Grid>
                </StackPanel>

                <ToggleButton Classes="export-checkbox-row"
                              IsChecked="{Binding ExportIncludeTacticalDrawings, Mode=TwoWay}">
                  <Grid ColumnDefinitions="16,*"
                        ColumnSpacing="12"
                        VerticalAlignment="Center">
                    <Border Width="16"
                            Height="16"
                            CornerRadius="4"
                            BorderBrush="#64748B"
                            BorderThickness="1"
                            Background="#1A1A1A">
                      <TextBlock HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FontSize="12"
                                 Foreground="#FFFFFF"
                                 Text="✓"
                                 IsVisible="{Binding #RootWindow.DataContext.ExportIncludeTacticalDrawings}"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Medium"
                               Text="Включить тактические рисунки"/>
                  </Grid>
                </ToggleButton>

                <StackPanel Spacing="12">
                  <TextBlock Classes="export-window-label"
                             Text="Куда сохранить"/>
                  <StackPanel Spacing="8">
                    <ToggleButton Classes="export-option-button full"
                                  IsChecked="{Binding IsExportDestinationFolderSelected}"
                                  Command="{Binding SelectExportDestinationCommand}"
                                  CommandParameter="Folder">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="12"
                                  VerticalAlignment="Center">
                        <Path Data="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.33"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Text="Сохранить в папку"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Classes="export-option-button full"
                                  IsChecked="{Binding IsExportDestinationTelegramSelected}"
                                  Command="{Binding SelectExportDestinationCommand}"
                                  CommandParameter="Telegram">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="12"
                                  VerticalAlignment="Center">
                        <Path Data="M22 2L11 13 M22 2l-7 20-4-9-9-4 20-7z"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.33"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Text="Отправить в Telegram"/>
                      </StackPanel>
                    </ToggleButton>
                    <ToggleButton Classes="export-option-button full"
                                  IsChecked="{Binding IsExportDestinationBothSelected}"
                                  Command="{Binding SelectExportDestinationCommand}"
                                  CommandParameter="Both">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="12"
                                  VerticalAlignment="Center">
                        <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M17 8l-5-5-5 5 M12 3v12"
                              Stroke="{Binding $parent[ToggleButton].Foreground}"
                              StrokeThickness="1.33"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Text="Оба варианта"/>
                      </StackPanel>
                    </ToggleButton>
                  </StackPanel>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Classes="export-window-label"
                             Text="Путь к папке"/>
                  <Border Classes="export-path-shell">
                    <TextBox Classes="export-path-input"
                             Text="{Binding ExportFolderPath}"/>
                  </Border>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    BorderBrush="#364153"
                    BorderThickness="0,1,0,0"
                    Padding="16">
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                <Button Grid.Column="0"
                        Classes="export-footer-secondary"
                        Command="{Binding CloseExportDialogCommand}"
                        IsEnabled="{Binding CanCloseExportDialog}"
                        Content="Отмена"/>
                <Button Grid.Column="1"
                        Classes="export-footer-primary"
                        Command="{Binding ExportFromDialogCommand}"
                        IsEnabled="{Binding CanExportFromDialog}">
                  <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Center"
                              Spacing="8">
                    <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M17 8l-5-5-5 5 M12 3v12"
                          Stroke="White"
                          StrokeThickness="1.33"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExportPrimaryButtonText}"/>
                  </StackPanel>
                </Button>
              </Grid>
            </Border>

            <Border Grid.RowSpan="3"
                    Background="#B8141720"
                    IsVisible="{Binding IsExportInProgress}">
              <Border Width="360"
                      Padding="24"
                      CornerRadius="20"
                      BorderBrush="#364153"
                      BorderThickness="1"
                      Background="#1A1D24"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                <StackPanel Spacing="16">
                  <TextBlock HorizontalAlignment="Center"
                             FontSize="24"
                             FontWeight="SemiBold"
                             Foreground="#F8FAFC"
                             Text="Рендерим видео"/>
                  <TextBlock Text="{Binding ExportProgressText}"
                             FontSize="14"
                             Foreground="#CBD5E1"
                             TextAlignment="Center"/>
                  <ProgressBar MinWidth="260"
                               Height="10"
                               IsIndeterminate="True"
                               Foreground="#155DFC"
                               Background="#0F172A"/>
                </StackPanel>
              </Border>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
  </Grid>
</Window>
























