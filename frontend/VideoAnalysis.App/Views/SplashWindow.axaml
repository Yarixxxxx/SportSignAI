<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VideoAnalysis.App.Views.SplashWindow"
        Width="760"
        Height="430"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#05070D">
  <Border CornerRadius="16"
          ClipToBounds="True"
          BorderBrush="#334155"
          BorderThickness="1"
          Background="#05070D">
    <Grid>
      <Image x:Name="SplashHeroImage"
             Stretch="UniformToFill"/>

      <Border Background="#74030912"/>

      <Border Height="190"
              VerticalAlignment="Bottom">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00000000" Offset="0"/>
            <GradientStop Color="#F0050710" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
      </Border>

      <Grid Margin="34"
            RowDefinitions="*,Auto">
        <StackPanel Grid.Row="1"
                    Spacing="14">
          <StackPanel Spacing="4">
            <TextBlock Text="VideoAnalytics"
                       Foreground="#F7FAFF"
                       FontSize="34"
                       FontWeight="Bold"/>
            <TextBlock Text="Подготовка хоккейной разметки"
                       Foreground="#C7D7EE"
                       FontSize="15"/>
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="14">
            <ProgressBar x:Name="SplashProgress"
                         Grid.Column="0"
                         Minimum="0"
                         Maximum="100"
                         Height="8"
                         Value="0"
                         Foreground="#2F86FF"
                         Background="#334155"/>
            <TextBlock x:Name="SplashPercentText"
                       Grid.Column="1"
                       Width="42"
                       Text="0%"
                       Foreground="#D9E5F8"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextAlignment="Right"
                       VerticalAlignment="Center"/>
          </Grid>

          <TextBlock x:Name="SplashStatusText"
                     Text="Загружаем модули анализа..."
                     Foreground="#8FA3BF"
                     FontSize="13"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
